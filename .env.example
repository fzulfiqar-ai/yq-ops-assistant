# YQ Bahrain ops assistant — environment template.
# Copy to .env and fill in real values. NEVER commit .env.

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Free LLM providers (app/llm_router.py) ---
# The rotation auto-includes every provider whose key is set. One OpenRouter key alone
# unlocks ~20 free models; add the fast first-party hosts below for a never-die rotation.
OPENROUTER_API_KEY=your-openrouter-key
GROQ_API_KEY=your-groq-key                 # console.groq.com  (fast, free)
CEREBRAS_API_KEY=your-cerebras-key         # cloud.cerebras.ai (fastest; serves free GLM-4.7)
# Strongest free capacity — get a free key (no card) at aistudio.google.com
GEMINI_API_KEY=
# Optional extra free providers (each auto-joins the rotation when set)
MISTRAL_API_KEY=                           # console.mistral.ai  (great multilingual / Arabic)
COHERE_API_KEY=                            # dashboard.cohere.com
GITHUB_MODELS_TOKEN=                       # github.com/marketplace/models (a GitHub PAT)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=                       # dash.cloudflare.com → Workers AI
SAMBANOVA_API_KEY=                          # cloud.sambanova.ai (very fast Llama 3.3 70B)
NVIDIA_API_KEY=                             # build.nvidia.com (DeepSeek / Llama / Nemotron, free)
MOONSHOT_API_KEY=                           # platform.moonshot.ai (Kimi K2 — strong long-context; generous free/cheap tier)
# Optional model-id overrides (defaults are measured-valid; change only if a model is renamed)
# CEREBRAS_GLM_MODEL=zai-glm-4.7
# GEMINI_MODEL=gemini-2.5-flash
# Legacy (dead keys — left for reference; rotation skips empty/!invalid)
SCALEWAY_API_KEY=
TOGETHER_API_KEY=
# Local embedding model for Phase-1 RAG memory (CPU/ONNX, no network → no PII egress)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Notifications (optional) ---
# Telegram (free): @BotFather → /newbot → token; message the bot then GET /getUpdates for chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Web search for vendor-sourcing agent (optional, free) ---
TAVILY_API_KEY=                            # tavily.com free tier
# YouTube Data API v3 — trend_radar video signals (10,000 free units/day)
YOUTUBE_API_KEY=                           # console.cloud.google.com → APIs & Services → Credentials

# --- App config ---
# Comma-separated list of allowed CORS origins (your Streamlit URL)
ALLOWED_ORIGINS=http://localhost:8501,https://your-app.streamlit.app
# Public base URL of the Streamlit portal — used to build invite links
APP_BASE_URL=https://your-app.streamlit.app

# --- Auth ---
# Per-user login is handled by Supabase Auth (no shared password).
# Bootstrap your first admin:  python -m scripts.manage_users set you@email.com 'pw' admin
# Machine key for schedulers / n8n agent flows (X-Agent-Key header)
AGENT_API_KEY=generate-a-long-random-secret

# --- Email (agent briefings + team invites) ---
# Railway blocks SMTP ports → use an HTTPS email API. Set ONE of RESEND/BREVO.
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_FROM=YQ Bahrain <onboarding@resend.dev>
ALERT_EMAIL_TO=furqanahmed223@gmail.com,fzulfiqar@pie-int.com
# SMTP fallback (works locally; blocked on Railway)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# --- Marketing & outreach (10k/month engine) — all optional, config-gated ---
# Kill switch for the outreach queue (drafts + sends). 0 = stop everything.
OUTREACH_ENABLED=1
# Owner's WhatsApp number (digits, e.g. 97333112233) — catalog CTA + assist-mode sends.
WA_HUMAN_NUMBER=
# HMAC secret for email opt-out links (falls back to SUPABASE_JWT_SECRET).
OPTOUT_SECRET=

# WhatsApp Cloud API (Phase 2 — use a SECOND SIM, never your daily WhatsApp number).
# developers.facebook.com → app → WhatsApp → API Setup.
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=
WA_AUTOREPLY_ENABLED=1
# Meta app secret — verifies X-Hub-Signature-256 on ALL Meta webhooks (WA + social).
META_APP_SECRET=

# Social publishing (Meta app in dev mode posts to YOUR OWN Page/IG — no app review).
FB_PAGE_ID=
FB_PAGE_TOKEN=
IG_BUSINESS_ID=

# Agnes AI (agnes-ai.com -> console -> API Keys) — free OpenAI-compatible AI image/video.
# Powers the content engine's video (image-to-video). Absent = local FFmpeg fallback.
AGNES_API_KEY=
