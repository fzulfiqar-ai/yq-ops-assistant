# YQ Bahrain ops assistant — environment template.
# Copy to .env and fill in real values. NEVER commit .env.

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Free LLM providers (app/llm_router.py) ---
OPENROUTER_API_KEY=your-openrouter-key
GROQ_API_KEY=your-groq-key
CEREBRAS_API_KEY=your-cerebras-key
SCALEWAY_API_KEY=your-scaleway-key
TOGETHER_API_KEY=your-together-key

# --- App config ---
# Comma-separated list of allowed CORS origins (your Streamlit URL)
ALLOWED_ORIGINS=http://localhost:8501,https://your-app.streamlit.app
