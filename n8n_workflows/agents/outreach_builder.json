{
  "name": "YQ Agent \u2014 Outreach Builder",
  "nodes": [
    {
      "id": "trigger",
      "name": "Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        260,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "weeks",
              "weeksInterval": 1,
              "triggerAtDay": [
                7
              ]
            }
          ]
        },
        "triggerAtHour": 7,
        "triggerAtMinute": 0
      }
    },
    {
      "id": "http",
      "name": "Run outreach_builder + email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        520,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "={{$env.RAILWAY_API_URL}}/agents/outreach_builder?email=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Agent-Key",
              "value": "={{$env.AGENT_API_KEY}}"
            }
          ]
        },
        "options": {
          "timeout": 60000
        }
      }
    }
  ],
  "connections": {
    "Schedule": {
      "main": [
        [
          {
            "node": "Run outreach_builder + email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}